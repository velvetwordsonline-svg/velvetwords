{
  "version": 2,
  "framework": "vite",
  "installCommand": "npm install",
  "buildCommand": "npm run build:client",
  "outputDirectory": "dist/spa",
  "routes": [
    {
      "src": "/admin/(.*)",
      "dest": "https://admin-three-zeta-82.vercel.app/$1"
    },
    {
      "src": "/api/(.*)",
      "dest": "https://velvetwords-backend.vercel.app/api/$1"
    }
  ]
}