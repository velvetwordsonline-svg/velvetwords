{
  "name": "velvet-words",
  "version": "1.0.0",
  "description": "A complete, production-ready, Kindle-like story platform with automatic multilingual translation using 100% free and open-source tools",
  "main": "index.js",
  "scripts": {
    "install-all": "npm run install-backend && npm run install-admin",
    "install-backend": "cd backend && npm install",
    "install-admin": "cd admin && npm install",
    "dev": "concurrently \"npm run dev-backend\" \"npm run dev-admin\"",
    "dev-backend": "cd backend && npm run dev",
    "dev-admin": "cd admin && npm run dev",
    "start": "concurrently \"npm run start-backend\" \"npm run start-admin\"",
    "start-backend": "cd backend && npm start",
    "start-admin": "cd admin && npm start",
    "build": "npm run build-backend && npm run build-admin",
    "build-backend": "cd backend && npm run build",
    "build-admin": "cd admin && npm run build",
    "seed": "cd backend && npm run seed",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "story-platform",
    "multilingual",
    "translation",
    "kindle-like",
    "docx-parser",
    "nodejs",
    "nextjs",
    "mongodb",
    "free",
    "open-source"
  ],
  "author": "Velvet Words Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/velvetwordsonline-svg/velvetwords.git"
  },
  "bugs": {
    "url": "https://github.com/velvetwordsonline-svg/velvetwords/issues"
  },
  "homepage": "https://github.com/velvetwordsonline-svg/velvetwords#readme",
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  }
}