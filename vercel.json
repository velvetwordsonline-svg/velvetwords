{
  "version": 2,
  "builds": [
    {
      "src": "New folder (5)/pulse-field/package.json",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/backend/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "/New folder (5)/pulse-field/dist/$1"
    }
  ],
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/New folder (5)/pulse-field/dist/index.html"
    }
  ]
}